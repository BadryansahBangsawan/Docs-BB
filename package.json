{
	"name": "docs-badry",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@types/node": "^22.13.14",
			"next-themes": "^0.4.6",
			"@libsql/client": "0.15.15",
			"libsql": "0.5.22",
			"@trpc/server": "^11.16.0",
			"@trpc/client": "^11.16.0",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "bun run --filter '*' dev",
		"build": "bun run --filter '*' build",
		"check-types": "bun run --filter '*' check-types",
		"dev:web": "bun run --filter web dev",
		"db:push": "bun run --filter @docs-badry/db db:push",
		"db:studio": "bun run --filter @docs-badry/db db:studio",
		"db:generate": "bun run --filter @docs-badry/db db:generate",
		"db:migrate": "bun run --filter @docs-badry/db db:migrate",
		"db:local": "bun run --filter @docs-badry/db db:local",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@docs-badry/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@docs-badry/config": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.12"
}
